# =============================================
# FIX Space — Environment Configuration Template
# =============================================
# Copy this file to .env.development (or .env.production) and fill in real values.
# Loading precedence: .env.${NODE_ENV} → .env (shared defaults)
# Secrets (DATABASE_URL, JWT_SECRET) MUST be set in environment-specific files.

# ── Server ──
# NODE_ENV is set by the runtime (shell / CI / cross-env), NOT in .env files.
# It controls which .env.${NODE_ENV} file is loaded — defaults to "development".
PORT=3000                           # API listen port
CORS_ORIGIN=http://localhost:3001   # Allowed CORS origin

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:password@localhost:5432/database_name?schema=public
DATABASE_POOL_SIZE=10               # Connection pool size

# ── Authentication (JWT & Tokens) ──
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_ACCESS_EXPIRATION=15m                      # Access token lifetime
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_REFRESH_EXPIRATION=7d                      # Refresh token lifetime
VERIFICATION_TOKEN_EXPIRATION_HOURS=24         # Email verification token TTL

# ── Cookies ──
COOKIE_DOMAIN=localhost                        # Cookie domain

# ── Email (SMTP) ──
# Leave SMTP_HOST empty to use Ethereal (dev mode with console preview URLs)
# In production, configure real SMTP credentials
SMTP_HOST=                                     # e.g. smtp.gmail.com
SMTP_PORT=587                                  # SMTP port
SMTP_USER=                                     # SMTP username
SMTP_PASS=                                     # SMTP password
MAIL_FROM=noreply@fixspace.app                  # Sender email address
APP_URL=http://localhost:3001                  # Frontend URL for verification links

# ── Docker / PostgreSQL container ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Two databases are created: fixspace (production) and fixspace_dev (development)
# See docker/init-databases.sql for initialization

# ── Application ──
SPACE_NAME_TEMPLATE={{username}}'s Space

