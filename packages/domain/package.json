{
  "name": "@fixspace/domain",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm build --watch",
    "build": "pnpm exec tsc -b tsconfig.build.json -v",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\""
  },
  "main": "./dist/entry.js",
  "types": "./dist/entry.d.ts",
  "files": [
    "./dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/entry.d.ts",
      "import": "./dist/entry.js",
      "require": "./dist/entry.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.js"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@nestjs/mapped-types": "*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3"
  },
  "devDependencies": {
    "nestjs-i18n": "^10.7.5",
    "@nestjs/swagger": "^11.4.4",
    "@fixspace/eslint-config": "workspace:*",
    "@fixspace/jest-config": "workspace:*",
    "@fixspace/typescript-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "typescript": "6.0.2"
  }
}
