datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

// ==============================
// Enums
// ==============================

enum PropertyType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  STATUS
  RELATION
  FORMULA
  RATING
  PROGRESS
}

enum AutomationTrigger {
  ON_RECORD_CREATE
}

enum AutomationStatus {
  SUCCESS
  FAILURE
  SKIPPED
}

enum NotificationType {
  SYSTEM
  ALERT
}

enum IntegrationService {
  BINANCE
  BYBIT
  OKX
  METATRADER5
  CTRADER
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==============================
// Auth models
// ==============================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  icon         String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())

  spaces                 Space[]
  settings               Settings[]
  refreshTokens          RefreshToken[]
  verificationTokens     EmailVerificationToken[]
  passwordResetTokens    PasswordResetToken[]
  googleAccount          GoogleAccount?
  notifications          Notification[]
  integrationConnections IntegrationConnection[]

  @@index([email])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model GoogleAccount {
  id             String   @id @default(uuid())
  userId         String   @unique
  googleId       String   @unique
  email          String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([googleId])
}

// ==============================
// User data models
// ==============================

model Settings {
  id       String @id @default(uuid())
  userId   String
  key      String
  value    Json
  category String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@index([category])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  text      String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model IntegrationConnection {
  id         String             @id @default(uuid())
  userId     String
  service    IntegrationService
  name       String
  credentials Json
  status     IntegrationStatus  @default(ACTIVE)
  lastSyncAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([service])
}

// ==============================
// Workspace models
// ==============================

model Space {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  icon      String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  databases Database[]
  sections  Section[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([name])
}

model Section {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  position  Int      @default(0)
  icon      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  databases Database[]

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([position])
}

// ==============================
// Core data models
// ==============================

model Database {
  id                 String   @id @default(uuid())
  spaceId            String
  sectionId          String?
  name               String
  title              String
  icon               String?
  recordLimit        Int?
  isPreset           Boolean  @default(false)
  isLocked           Boolean  @default(false)
  useDefaultTemplate Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  space          Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  section        Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  properties     Property[]
  records        Record[]
  templates      Template[]
  views          View[]
  automations    Automation[]
  importMappings ImportMapping[]

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([sectionId])
}

model Property {
  id          String       @id @default(uuid())
  databaseId  String
  name        String
  type        PropertyType
  position    Int
  icon        String?
  hint        String?
  group       String?
  isRequired  Boolean      @default(false)
  isVisible   Boolean      @default(true)
  isProtected Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  config      Json?

  database       Database                @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values         PropertyValue[]
  templateValues TemplatePropertyValue[]

  @@index([databaseId])
  @@index([position])
}

model Record {
  id         String    @id @default(uuid())
  databaseId String
  templateId String?
  name       String    @default("Untitled")
  icon       String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  database       Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  sourceTemplate Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  values         PropertyValue[]
  content        RecordContent?

  @@index([databaseId])
  @@index([templateId])
  @@index([createdAt])
  @@index([deletedAt])
}

model PropertyValue {
  id         String  @id @default(uuid())
  recordId   String
  propertyId String
  value      Json?
  computed   Boolean @default(false)

  record   Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([recordId, propertyId])
  @@index([recordId])
  @@index([propertyId])
}

model RecordContent {
  id           String   @id @default(uuid())
  recordId     String   @unique
  content      Json     @default("{}")
  lastEditedAt DateTime @default(now()) @updatedAt

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

// ==============================
// Template models
// ==============================

model Template {
  id          String   @id @default(uuid())
  databaseId  String
  name        String   @default("Untitled")
  description String?
  icon        String?
  isDefault   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  config      Json?

  database Database                @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values   TemplatePropertyValue[]
  records  Record[]

  @@unique([databaseId, name])
  @@index([databaseId])
  @@index([position])
}

model TemplatePropertyValue {
  id         String @id @default(uuid())
  templateId String
  propertyId String
  value      Json?

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([templateId, propertyId])
  @@index([templateId])
  @@index([propertyId])
}

// ==============================
// Views & Automation models
// ==============================

model View {
  id            String   @id @default(uuid())
  databaseId    String
  name          String
  isDefault     Boolean  @default(false)
  isLocked      Boolean  @default(false)
  filters       Json?
  sort          Json?
  groupBy       String?
  hiddenColumns String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

model Automation {
  id         String            @id @default(uuid())
  databaseId String
  name       String
  trigger    AutomationTrigger
  condition  Json?
  actions    Json
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  config     Json?

  database Database       @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  logs     AutomationLog[]

  @@index([databaseId])
  @@index([active])
}

model AutomationLog {
  id             String           @id @default(uuid())
  automationId   String
  sourceRecordId String?
  status         AutomationStatus
  result         String?
  createdAt      DateTime         @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([status])
}

// ==============================
// Import models
// ==============================

model ImportMapping {
  id           String   @id @default(uuid())
  databaseId   String
  name         String
  sourceType   String
  mappingRules Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  database Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  imports  ImportHistory[]

  @@index([databaseId])
}

model ImportHistory {
  id              String       @id @default(uuid())
  importMappingId String
  status          ImportStatus
  recordsCreated  Int          @default(0)
  recordsFailed   Int          @default(0)
  errorLog        Json?
  sourceFileInfo  Json
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  importMapping ImportMapping @relation(fields: [importMappingId], references: [id], onDelete: Cascade)

  @@index([importMappingId])
  @@index([status])
}
