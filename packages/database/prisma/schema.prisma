// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

// ==============================
// Enums
// ==============================

enum PropertyType {
  TEXT
  NUMBER
  DATE
}

enum ViewType {
  TABLE
  LIST
}

enum AutomationTrigger {
  ON_RECORD_CREATE
}

enum AIInsightType {
  RECORD_ANALYSIS
}

// ==============================
// Core models
// ==============================

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  username       String   @unique
  passwordHash   String
  createdAt      DateTime @default(now())
  settingsConfig Json?

  spaces Space[]
}

model Space {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())
  config    Json?

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  databases Database[]
  sections  Section[]

  @@unique([ownerId, name])
  @@index([name])
}

model Section {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  position  Int      @default(0)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  databases Database[]

  @@unique([spaceId, name])
  @@index([spaceId])
}

model Database {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  config    Json?

  space       Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  properties  Property[]
  records     Record[]
  views       View[]
  automations Automation[]
  section     Section?     @relation(fields: [sectionId], references: [id])
  sectionId   String?

  @@unique([spaceId, name])
  @@index([spaceId])
}

model Property {
  id         String       @id @default(uuid())
  databaseId String
  name       String
  type       PropertyType
  position   Int
  isRequired Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  config     Json?

  database Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values   PropertyValue[]

  @@index([databaseId])
}

model Record {
  id         String    @id @default(uuid())
  databaseId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  status     String?
  archivedAt DateTime?
  config     Json?

  database Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values   PropertyValue[]
  content  RecordContent?

  @@index([databaseId])
}

model PropertyValue {
  id         String  @id @default(uuid())
  recordId   String
  propertyId String
  value      Json?
  computed   Boolean @default(false)

  record   Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([recordId, propertyId])
  @@index([recordId])
  @@index([propertyId])
}

model RecordContent {
  id           String   @id @default(uuid())
  recordId     String   @unique
  blocks       Json?
  lastEditedAt DateTime @default(now())
  config       Json?

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

model View {
  id         String   @id @default(uuid())
  databaseId String
  name       String
  type       ViewType
  config     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

model Automation {
  id         String            @id @default(uuid())
  databaseId String
  name       String
  trigger    AutomationTrigger
  condition  Json?
  action     Json?
  active     Boolean           @default(true)
  config     Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

model AIInsight {
  id        String        @id @default(uuid())
  scopeType String
  scopeId   String
  type      AIInsightType
  input     Json?
  output    Json?
  createdAt DateTime      @default(now())
  config    Json?

  @@index([scopeType, scopeId])
}
