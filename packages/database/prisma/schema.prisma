// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

// ==============================
// Enums
// ==============================

enum PropertyType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  STATUS
  RELATION
  FORMULA
}

enum AutomationTrigger {
  ON_RECORD_CREATE
}

// ==============================
// Core models
// ==============================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  icon         String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())

  spaces              Space[]
  settings            Settings[]
  refreshTokens       RefreshToken[]
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Settings {
  id       String @id @default(uuid())
  userId   String
  key      String
  value    Json
  category String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@index([category])
}

model Space {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  icon      String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  databases Database[]
  sections  Section[]
  //workflowCanvases WorkflowCanvas[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([name])
}

model Section {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  position  Int      @default(0)
  icon      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  databases Database[]

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([position])
}

model Database {
  id          String   @id @default(uuid())
  spaceId     String
  sectionId   String?
  name        String
  title       String
  icon        String?
  recordLimit         Int?
  useDefaultTemplate  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space      Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  section    Section?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  properties Property[]
  records    Record[]
  //importMappings   ImportMapping[]
  //workflowCanvases WorkflowCanvas[]
  //views       View[]
  //automations Automation[]
  templates    Template[]

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([sectionId])
}

model Property {
  id         String       @id @default(uuid())
  databaseId String
  name       String
  type       PropertyType
  position   Int
  icon       String?
  hint       String?
  group      String?
  isRequired Boolean      @default(false)
  isVisible  Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  config     Json?

  database Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values         PropertyValue[]
  templateValues TemplatePropertyValue[]

  @@index([databaseId])
  @@index([position])
}

model Record {
  id         String   @id @default(uuid())
  databaseId String
  templateId String?
  name       String   @default("Untitled")
  icon       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  database Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  sourceTemplate Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  values   PropertyValue[]
  content  RecordContent?

  @@index([databaseId])
  @@index([templateId])
  @@index([createdAt])
}

model PropertyValue {
  id         String  @id @default(uuid())
  recordId   String
  propertyId String
  value      Json?
  computed   Boolean @default(false)

  record   Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([recordId, propertyId])
  @@index([recordId])
  @@index([propertyId])
}

model RecordContent {
  id           String   @id @default(uuid())
  recordId     String   @unique
  lastEditedAt DateTime @default(now())

  record Record @relation(fields: [recordId], references: [id], onDelete: Cascade)
  //gridItems GridItem[]
}

model Template {
  id          String   @id @default(uuid())
  databaseId  String
  name        String   @default("Untitled")
  description String?
  icon        String?
  isDefault   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  config      Json?

  database Database               @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values   TemplatePropertyValue[]
  records  Record[]

  @@unique([databaseId, name])
  @@index([databaseId])
  @@index([position])
}

model TemplatePropertyValue {
  id         String  @id @default(uuid())
  templateId String
  propertyId String
  value      Json?

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([templateId, propertyId])
  @@index([templateId])
  @@index([propertyId])
}

