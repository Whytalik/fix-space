{
  "name": "@nucleus/database",
  "version": "1.0.0",
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "format": "prisma format",
    "lint": "eslint . --max-warnings 0",
    "studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "latest",
    "@prisma/client-runtime-utils": "7.2.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@nucleus/eslint-config": "workspace:*",
    "@nucleus/typescript-config": "workspace:*",
    "@types/pg": "^8.16.0",
    "eslint": "^8.57.0",
    "prisma": "latest",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "tsx": "4.19.1",
    "typescript": "5.5.4"
  }
}
