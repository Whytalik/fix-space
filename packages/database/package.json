{
  "name": "@nucleus/database",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migrate:deploy": "dotenv -e ../../.env.production -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env.development -e ../../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../.env.development -e ../../.env -- prisma db push",
    "db:seed": "dotenv -e ../../.env.development -e ../../.env -- tsx src/seed.ts",
    "db:generate": "dotenv -e ../../.env.development -e ../../.env -- prisma generate",
    "format": "dotenv -e ../../.env.development -e ../../.env -- prisma format",
    "lint": "eslint . --max-warnings 0",
    "studio": "dotenv -e ../../.env.development -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "7.5.0",
    "@prisma/client-runtime-utils": "7.5.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@nucleus/eslint-config": "workspace:*",
    "@nucleus/typescript-config": "workspace:*",
    "@types/pg": "8.11.11",
    "eslint": "^9.39.2",
    "prisma": "7.5.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "tsx": "4.19.1",
    "typescript": "6.0.2"
  }
}
