@startuml Sequence_FormulaEvaluation

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Formula Evaluation Pipeline

actor "User" as U
participant "Browser\n(Next.js)" as FE
participant "API\n(NestJS)" as API
participant "PropertyValueService" as PVS
participant "FormulaHandler" as FH
participant "Database\n(PostgreSQL)" as DB

== Trigger: dependent field changes ==

U -> FE : Edit property value\n(e.g. P&L = 150)
FE -> API : PATCH /property-values/:id\n{ value: 150 }
API -> PVS : update(id, value, userId)
PVS -> DB : UPDATE PropertyValue
DB --> PVS : Updated value

PVS -> DB : Find all FORMULA properties\nin same database
DB --> PVS : List of FORMULA PropertyValues

loop for each FORMULA property
  PVS -> FH : evaluate(formula, record, allValues)
  FH -> FH : Resolve input fields\nfrom same record
  FH -> FH : Execute calculation\n(preset or custom expression)

  alt preset formula (e.g. R-Multiple)
    FH -> FH : result = P&L / Risk
  else custom expression
    FH -> FH : Walk expression tree\n(max 2 levels deep)
  end

  FH --> PVS : Computed value
  PVS -> DB : UPDATE FORMULA PropertyValue
  DB --> PVS : OK
end

PVS --> API : RecordResponseDto\n(all updated values)
API --> FE : 200 OK { record }
FE --> U : Re-render updated cells

@enduml
