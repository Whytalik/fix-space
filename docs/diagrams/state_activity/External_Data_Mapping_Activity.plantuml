@startuml External_Data_Mapping_Activity

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 12
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #000000
  BarColor #000000
  StartColor #000000
  EndColor #000000
  ArrowColor #000000
  FontColor #000000
}

title Алгоритм парсингу та мапінгу зовнішніх даних

|Джерело даних|
start
fork
  :Завантаження CSV файлу;
  :Перевірка формату та MIME-типу;
  :Парсинг буфера у масив рядків;
  :Мапінг колонок згідно з JSON конфігурацією;
  :Конвертація значень у типи властивостей;
fork again
  :Запит до API Binance;
  :Отримання сирих даних про виконання угод;
  :Агрегація виконань у позиції;
  :Розрахунок результату та комісій;
fork again
  :Отримання вебхука від MetaTrader;
  :Перевірка ключа доступу в заголовку;
  :Валідація структури вхідного JSON;
end fork

|Уніфікований рівень обробки|
partition "Мапінг у внутрішню схему" {
  :Формування об'єкта TradeData;
  :Пошук бази даних типу "Торговий журнал";
  
  if (Журнал знайдено?) then (так)
    :Отримання властивостей бази даних;
    :Автоматичне відновлення ключів інтеграції за іменами;
    :Побудова карти відповідності ключів та ID властивостей;
  else (ні)
    :Вивід попередження про відсутність цільової бази;
    stop
  endif
}

partition "Валідація та дедуплікація" {
  :Перевірка наявності обов'язкових полів;
  :Пошук існуючих записів за унікальним ID джерела;
  :Фільтрація вже імпортованих позицій;
  
  if (Є нові дані?) then (так)
  else (ні)
    :Завершення: Дані вже актуальні;
    stop
  endif
}

partition "Збереження (Транзакція)" {
  :Трансформація значень для інтерфейсу;
  note right: Наприклад: BUY стає Long, PnL > 0 стає Win
  
  while (Є нові записи?) is (так)
    :Створення основного запису (Record);
    :Створення значень властивостей (PropertyValue);
    :Прив'язка до ID інтеграції та джерела;
  endwhile (ні)
}

|Користувач / UI|
:Відображення результату імпорту;
stop

@enduml
