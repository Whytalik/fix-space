@startuml ER_Diagram

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam packageStyle rectangle
skinparam padding 1
skinparam titlePadding 2

skinparam class {
  BackgroundColor White
  BorderColor #2563eb
  AttributeFontName monospace
  AttributeFontSize 8
  FontSize 9
  ArrowColor #2563eb
  BorderThickness 1.5
}

skinparam nodesep 4
skinparam ranksep 5
skinparam defaultFontSize 9
skinparam linetype ortho

title ER-діаграма бази даних — нотація Crow's Foot

class User {
  [PK] id: String
  email: String
  username: String
  passwordHash: String
  icon: String
  isVerified: Boolean
  createdAt: DateTime
}

class RefreshToken {
  [PK] id: String
  [FK] userId: String
  tokenHash: String
  expiresAt: DateTime
  createdAt: DateTime
  revokedAt: DateTime
}

class EmailVerificationToken {
  [PK] id: String
  [FK] userId: String
  tokenHash: String
  expiresAt: DateTime
  createdAt: DateTime
  usedAt: DateTime
}

class PasswordResetToken {
  [PK] id: String
  [FK] userId: String
  tokenHash: String
  expiresAt: DateTime
  createdAt: DateTime
  usedAt: DateTime
}

class GoogleAccount {
  [PK] id: String
  [FK] userId: String
  googleId: String
  email: String
  accessToken: String
  refreshToken: String
  tokenExpiresAt: DateTime
}

class Settings {
  [PK] id: String
  [FK] userId: String
  key: String
  value: JSONB
  category: String
}

class Notification {
  [PK] id: String
  [FK] userId: String
  type: NotificationType
  text: String
  isRead: Boolean
  link: String
  createdAt: DateTime
}

class IntegrationConnection {
  [PK] id: String
  [FK] userId: String
  service: IntegrationService
  name: String
  credentials: JSONB
  status: IntegrationStatus
  syncInterval: Int
  marketType: String
  externalAccountId: String
  lastSyncAt: DateTime
  lastSyncError: String
  consecutiveFailures: Int
  createdAt: DateTime
  updatedAt: DateTime
}

class ContentBlockLibrary {
  [PK] id: String
  [FK] userId: String
  name: String
  content: JSONB
  isSystem: Boolean
  isVisible: Boolean
  createdAt: DateTime
  updatedAt: DateTime
}

class Space {
  [PK] id: String
  [FK] ownerId: String
  name: String
  icon: String
  isDefault: Boolean
  isDemo: Boolean
  createdAt: DateTime
  config: JSONB
}

class Section {
  [PK] id: String
  [FK] spaceId: String
  name: String
  key: String
  position: Int
  icon: String
  color: String
  createdAt: DateTime
  updatedAt: DateTime
}

class Database {
  [PK] id: String
  [FK] spaceId: String
  [FK] sectionId: String
  name: String
  title: String
  type: String
  key: String
  icon: String
  position: Int
  isPreset: Boolean
  isLocked: Boolean
  enableStats: Boolean
  createdAt: DateTime
  updatedAt: DateTime
  config: JSONB
}

class PropertyGroup {
  [PK] id: String
  [FK] databaseId: String
  name: String
  position: Int
  visibility: JSONB
  createdAt: DateTime
  updatedAt: DateTime
}

class Property {
  [PK] id: String
  [FK] databaseId: String
  [FK] groupId: String
  name: String
  type: PropertyType
  position: Int
  icon: String
  hint: String
  group: String
  isVisible: Boolean
  isProtected: Boolean
  createdAt: DateTime
  updatedAt: DateTime
  config: JSONB
}

class Record {
  [PK] id: String
  [FK] databaseId: String
  [FK] templateId: String
  sourceIntegrationId: String
  sourceLabel: String
  sourcePositionId: String
  sourceCurrency: String
  name: String
  icon: String
  config: JSONB
  deletedAt: DateTime
  createdAt: DateTime
  updatedAt: DateTime
}

class PropertyValue {
  [PK] id: String
  [FK] recordId: String
  [FK] propertyId: String
  value: JSONB
  computed: Boolean
}

class RecordContent {
  [PK] id: String
  [FK] recordId: String
  content: JSONB
  lastEditedAt: DateTime
}

class RecordContentSnapshot {
  [PK] id: String
  [FK] recordContentId: String
  content: JSONB
  createdAt: DateTime
}

class Template {
  [PK] id: String
  [FK] databaseId: String
  name: String
  description: String
  icon: String
  namePattern: String
  content: JSONB
  isDefault: Boolean
  position: Int
  createdAt: DateTime
  updatedAt: DateTime
  config: JSONB
}

class TemplatePropertyValue {
  [PK] id: String
  [FK] templateId: String
  [FK] propertyId: String
  value: JSONB
}

class View {
  [PK] id: String
  [FK] databaseId: String
  name: String
  icon: String
  isDefault: Boolean
  isLocked: Boolean
  pageSize: Int
  recordLimit: Int
  useDefaultTemplate: Boolean
  defaultTemplateId: String
  filters: JSONB
  filterLogic: FilterLogic
  sort: JSONB
  groupBy: String
  hiddenColumns: String[]
  columnWidths: JSONB
  textWrap: Boolean
  searchQuery: String
  config: JSONB
  createdAt: DateTime
  updatedAt: DateTime
}

class Automation {
  [PK] id: String
  [FK] databaseId: String
  name: String
  trigger: AutomationTrigger
  condition: JSONB
  actions: JSONB
  active: Boolean
  createdAt: DateTime
  updatedAt: DateTime
  config: JSONB
}

class AutomationLog {
  [PK] id: String
  [FK] automationId: String
  sourceRecordId: String
  status: AutomationStatus
  result: String
  createdAt: DateTime
}

class ImportMapping {
  [PK] id: String
  [FK] databaseId: String
  name: String
  sourceType: String
  mappingRules: JSONB
  createdAt: DateTime
  updatedAt: DateTime
}

class ImportHistory {
  [PK] id: String
  [FK] importMappingId: String
  status: ImportStatus
  recordsCreated: Int
  recordsFailed: Int
  errorLog: JSONB
  sourceFileInfo: JSONB
  createdAt: DateTime
  completedAt: DateTime
}

User -[hidden]- Space
Space -[hidden]- Database
Database -left[hidden]- PropertyGroup
Database -left[hidden]- Property
Database -left[hidden]- Record

User "1" -- "0..*" Space
User "1" -- "0..*" Settings
User "1" -- "0..*" RefreshToken
User "1" -- "0..*" EmailVerificationToken
User "1" -- "0..*" PasswordResetToken
User "1" -- "0..*" Notification
User "1" -- "0..*" IntegrationConnection
User "1" -- "0..*" ContentBlockLibrary
User "1" -- "0..1" GoogleAccount

Space "1" -- "0..*" Section
Space "1" -- "0..*" Database

Section "0..1" -- "0..*" Database

Database "1" -- "0..*" PropertyGroup
Database "1" -- "0..*" Property
Database "1" -- "0..*" Record
Database "1" -- "0..*" Template
Database "1" -- "0..*" View
Database "1" -- "0..*" Automation
Database "1" -- "0..*" ImportMapping

PropertyGroup "0..1" -- "0..*" Property

Property "1" -- "0..*" PropertyValue
Property "1" -- "0..*" TemplatePropertyValue

Record "1" -- "0..*" PropertyValue
Record "1" -- "1" RecordContent
Template "1" -- "0..*" Record

RecordContent "1" -- "0..*" RecordContentSnapshot

Template "1" -- "0..*" TemplatePropertyValue

Automation "1" -- "0..*" AutomationLog

ImportMapping "1" -- "0..*" ImportHistory

@enduml
