@startuml Deployment

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 14
skinparam nodesep 50
skinparam ranksep 60

skinparam nodeBackgroundColor #FFFFFF
skinparam nodeBorderColor #2563eb
skinparam nodeArrowColor #2563eb
skinparam artifactBackgroundColor #FFFFFF
skinparam artifactBorderColor #2563eb
skinparam databaseBackgroundColor #FFFFFF
skinparam databaseBorderColor #2563eb

top to bottom direction

title Діаграма розгортання системи FixSpace

node "GitHub Actions" as GitHub #F8F9FA {
  artifact "CI/CD Pipeline\n(Пайплайни)" as Pipeline
}

node "Vercel (PaaS)" as Vercel_Node #F8F9FA {
  artifact "Static Assets\n(JS, CSS, зображення)" as Static
  artifact "SSR Pages\n(Next.js 16 / React 19)" as SSR
  artifact "CDN Edge Cache" as CDN
  artifact "Vercel Monitoring\n(Web Vitals, логи)" as Monitor
}

node "Railway (PaaS)" as Railway_Node #F8F9FA {
  artifact "NestJS 11 API\n(Docker Container)" as NestJS
  database "PostgreSQL 16\n(Prisma ORM 7)" as PgDB
  database "Redis 7\n(Кешування)" as Redis
  artifact "Railway Secrets\n(Змінні оточення)" as Env
}

node "Зовнішні сервіси (SaaS)" as Ext_Node #FFF9C4 {
  artifact "Google OAuth 2.0" as Google
  artifact "Resend API / SMTP" as Resend
  artifact "Cloudinary API" as Cloudinary
  artifact "Trading Platforms\n(Binance, MT5)" as Trading
}

node "Термінал користувача" as User_Terminal #F8F9FA {
  node "MetaTrader 5" as MT5 {
    artifact "FixSpaceSync.mq5\n(Expert Advisor)" as EA
  }
}

GitHub ..> Vercel_Node : Deploy (Next.js)
GitHub ..> Railway_Node : Deploy (Docker/NestJS)

Static ..> NestJS : HTTPS REST API
SSR ..> NestJS : HTTPS REST API (SSR)
CDN ..> SSR : Edge-кешування

NestJS ..> PgDB : TCP/IP (SSL)
NestJS ..> Redis : TCP/IP
NestJS ..> Resend : HTTPS API / SMTP
NestJS ..> Google : OAuth 2.0
NestJS ..> Cloudinary : HTTPS API
NestJS ..> Trading : HTTPS API

EA ..> NestJS : HTTPS REST API (WebRequest)

SSR ..> Monitor : Web Vitals
Env ..> NestJS : Конфігурація

@enduml
