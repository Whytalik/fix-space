        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"{{reset_token}}\",\n    \"newPassword\": \"NewPass1234!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "reset-password"]
            }
          },
          "response": []
        },
        {
          "name": "Dev",
          "item": [
            {
              "name": "Dev — Verify User",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"email\": \"test@example.com\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{base_url}}/auth/dev/verify-user",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "dev", "verify-user"]
                },
                "description": "Тільки для NODE_ENV=development. Вручну активує користувача без пошти."
              },
              "response": []
            },
            {
              "name": "Dev — Reset Test Data",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"email\": \"test@example.com\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{base_url}}/auth/dev/reset",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "dev", "reset"]
                },
                "description": "Тільки для NODE_ENV=development. Повністю видаляє акаунт для повторної реєстрації."
              },
              "response": []
            }
          ]
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Dynamic environment switching based on 'env' variable",
          "const currentEnv = pm.collectionVariables.get('env') || 'local';",
          "const baseUrl = pm.collectionVariables.get(currentEnv + '_url');",
          "pm.collectionVariables.set('base_url', baseUrl);",
          "",
          "console.log(`Running in ${currentEnv} mode: ${baseUrl}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "env",
      "value": "local",
      "type": "string"
    },
    {
      "key": "local_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "production_url",
      "value": "https://fix-space-production.up.railway.app",
      "type": "string"
    },
    {
      "key": "base_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "verification_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "reset_token",
