        {
          "name": "4. GET /spaces — Check Presets",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "",
                  "pm.test(\"Has at least 1 workspace\", () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res).to.be.an(\"array\").that.is.not.empty;",
                  "});",
                  "",
                  "pm.test(\"First workspace is default\", () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res[0]).to.have.property(\"isDefault\", true);",
                  "    pm.collectionVariables.set(\"space_id\", res[0].id);",
                  "});",
                  "",
                  "pm.test(\"Has 9 preset databases\", () => {",
                  "    const res = pm.response.json();",
                  "    const dbTypes = res[0].databases.map(db => db.type);",
                  "    const expected = [",
                  "        \"trading-journal\", \"daily-routine\", \"routine-library\",",
                  "        \"notes\", \"mistakes\", \"accounts\", \"operations\",",
                  "        \"trading-system\", \"performance-review\"",
                  "    ];",
                  "    expected.forEach(type => {",
                  "        pm.expect(dbTypes).to.include(type, `Missing database type: ${type}`);",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Trading Journal has FORMULA properties\", () => {",
                  "    const res = pm.response.json();",
                  "    const tjDb = res[0].databases.find(db => db.type === \"trading-journal\");",
                  "    pm.expect(tjDb).to.not.be.undefined;",
                  "    const propNames = tjDb.properties.map(p => p.name);",
                  "    pm.expect(propNames).to.include(\"Net P&L\");",
                  "    pm.expect(propNames).to.include(\"Risk %\");",
                  "    pm.expect(propNames).to.include(\"Actual R\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/spaces",
              "host": ["{{base_url}}"],
              "path": ["spaces"]
            }
          },
