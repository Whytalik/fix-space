{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "**/.env",
    "**/.env.development",
    "**/.env.production"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "JWT_SECRET",
    "PORT",
    "CORS_ORIGIN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "db:migrate:dev": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL"]
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "cache": false
    },
    "lint": {},
    "test": {},
    "test:e2e": {}
  }
}
