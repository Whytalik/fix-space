{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "**/.env",
    "**/.env.development",
    "**/.env.production"
  ],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DATABASE_PUBLIC_URL",
    "DATABASE_POOL_SIZE",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_ACCESS_EXPIRATION",
    "JWT_REFRESH_EXPIRATION",
    "PORT",
    "CORS_ORIGIN",
    "APP_URL",
    "COOKIE_DOMAIN",
    "COOKIE_SECURE",
    "INTERNAL_API_URL",
    "MAIL_FROM",
    "RESEND_API_KEY",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SPACE_NAME_TEMPLATE",
    "VERIFICATION_TOKEN_EXPIRATION_HOURS",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_DB",
    "PGUSER",
    "PGPASSWORD",
    "PGDATABASE",
    "PGHOST",
    "PGPORT",
    "PGDATA",
    "SSL_CERT_DAYS",
    "RAILWAY_DEPLOYMENT_DRAINING_SECONDS",
    "CI",
    "CLOUDINARY_CLOUD_NAME",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "CLOUDINARY_AVATAR_FOLDER"
  ],

  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NODE_ENV"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".eslintrc*", "eslint.config.*"],
      "outputs": []
    },
    "format": {
      "inputs": ["$TURBO_DEFAULT$", ".prettierrc*"],
      "cache": false,
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["generated/**"],
      "cache": true
    },
    "db:migrate:dev": {
      "cache": false,
      "outputs": []
    },
    "db:migrate:deploy": {
      "cache": false,
      "outputs": []
    },
    "db:push": {
      "cache": false,
      "outputs": []
    }
  }
}
