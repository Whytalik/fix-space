{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "refactor",
        "chore",
        "docs",
        "test",
        "ci",
        "style",
        "perf",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "auth",
        "workspace",
        "database",
        "property",
        "record",
        "view",
        "template",
        "content",
        "formula",
        "automation",
        "statistics",
        "settings",
        "onboarding",
        "notification",
        "search",
        "import-export",
        "integration",
        "section",
        "api",
        "web",
        "deps",
        "ci"
      ]
    ],
    "subject-case": [0],
    "subject-empty": [2, "never"],
    "type-empty": [2, "never"]
  }
}
