{
  "extends": "@fixspace/typescript-config/nestjs.json",
  "include": ["src/**/*", "test/**/*"],
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist",
    "rootDir": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/common/*": ["src/common/*"],
      "@/core/*": ["src/core/*"]
    }
  }
}
