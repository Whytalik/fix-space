    "workspace": "Workspace",
    "everythingTrader": {
      "title": "Everything a CFD trader needs",
      "description": "Seven databases with trade-aware properties, formula fields, and default templates — created automatically when you register. No blank canvas, no setup."
    },
    "features": {
      "tradingJournal": {
        "title": "Trading Journal",
        "description": "Log every trade with full context — instrument, direction, entry/exit, lot size, P&L, R:R, and setups. Your history becomes your best teacher."
      },
      "dailyRoutine": {
        "title": "Daily Routine",
        "description": "Structure your pre-session prep and post-session review with checklists. Build habits that compound into systemic performance."
      },
      "knowledgeBase": {
        "title": "Knowledge Base",
        "description": "Capture market observations, research, and insights in categorized records. Build your own library of market edge."
      },
      "mistakesPsychology": {
        "title": "Mistakes & Psychology",
        "description": "Track recurring behavioral errors and discipline breaks. Identify psychological patterns before they affect your capital."
      },
      "accountsManagement": {
        "title": "Accounts Management",
        "description": "Monitor balances, drawdowns, and leverage across all your broker accounts. A complete financial overview in one place."
      },
      "smartDatabases": {
        "title": "Smart Databases",
        "description": "Define your own properties: text, numbers, dates, and relations. Link an error to a specific session with a single click."
      },
      "tradingSystem": {
        "title": "Trading System",
        "description": "Document your strategy rules, entry criteria, and risk parameters. Version and evaluate your edge as the market evolves."
      }
    },
    "templates": "Templates",
    "neverBlankPage": {
      "title": "Never start from a blank page",
      "description": "FIX Space ships with pre-built templates for trade logs, session reviews, and strategy documents. When creating a new record, a template is applied automatically — you get a ready-made page structure and can start filling it immediately. Build your own templates to match your personal workflow."
    },
