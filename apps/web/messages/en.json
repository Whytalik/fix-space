    "focus": "Focus",
    "builtForTraders": {
      "title": "Built for traders, not for everyone",
      "description": "Generic tools give you flexibility but no domain knowledge. Specialized journals know trading but lock you into a rigid structure. FIX Space is the first tool that offers both — a purpose-built trading workspace you can adapt to your own style."
    },
    "genericTools": "Generic tools",
    "notionGoogleSheets": "Notion / Google Sheets",
    "noTradingModel": "No trading model — build databases, properties, and formulas from scratch.",
