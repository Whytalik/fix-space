{
  "name": "my-turborepo",
  "version": "0.0.0",
  "private": true,
  "author": "Vitalii Tushak",
  "license": "UNLICENSED",
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "cross-env NODE_ENV=development turbo run dev --filter=@fixspace/api",
    "build": "turbo run build",
    "start:prod": "cross-env NODE_ENV=production node apps/api/dist/main.js",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:integration": "docker compose --profile test up -d --wait db-test && pnpm --filter @fixspace/api test:e2e",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:migrate:dev": "turbo run db:migrate:dev",
    "db:migrate:deploy": "cross-env NODE_ENV=production turbo run db:migrate:deploy",
    "db:push": "turbo run db:push",
    "db:generate": "turbo run db:generate",
    "db:reset": "docker-compose down -v && docker-compose up -d && pnpm --filter @fixspace/database db:migrate:dev",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "sync:issues": "node scripts/sync-from-issues.js",
    "prepare": "node -e \"if(process.env.CI || process.env.NODE_ENV === 'production') process.exit(0); require('child_process').execSync('husky', {stdio: 'inherit'});\""
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.2",
    "@fixspace/eslint-config": "workspace:*",
    "@fixspace/typescript-config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@typescript/native-preview": "7.0.0-dev.20260524.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.2.5",
    "prisma": "latest",
    "tsx": "4.19.1",
    "turbo": "^2.8.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "latest"
  },
  "pnpm": {
    "overrides": {
      "@types/pg": "8.11.11",
      "multer": "^2.1.1",
      "hono": "^4.12.4",
      "effect": "^3.20.0",
      "fast-uri": "^3.1.2",
      "picomatch": "^2.3.2",
      "path-to-regexp": "^8.4.0",
      "lodash": "^4.18.0",
      "handlebars": "^4.7.9",
      "flatted": "^3.4.2",
      "undici": "^7.24.0",
      "@hono/node-server": "^1.19.10"
    }
  },
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "**/*.{ts,tsx,md,json}": "prettier --write"
  }
}
