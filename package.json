{
  "name": "my-turborepo",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "author": "",
  "license": "UNLICENSED",
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "tsx packages/database/src/seed.ts"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "cross-env NODE_ENV=development turbo run dev --filter=@nucleus/api",
    "build": "turbo run build",
    "start:prod": "cross-env NODE_ENV=production node apps/api/dist/main.js",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:migrate:dev": "turbo run db:migrate:dev",
    "db:migrate:deploy": "cross-env NODE_ENV=production turbo run db:migrate:deploy",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "db:generate": "turbo run db:generate",
    "db:reset": "docker-compose down -v && docker-compose up -d && turbo db:migrate:dev",
    "setup:hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push scripts/update-changelog.sh && echo \"Git hooks configured.\""
  },
  "devDependencies": {
    "@nucleus/eslint-config": "workspace:*",
    "@nucleus/typescript-config": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "prisma": "latest",
    "tsx": "4.19.1",
    "turbo": "^2.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "latest"
  },
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=18"
  }
}
